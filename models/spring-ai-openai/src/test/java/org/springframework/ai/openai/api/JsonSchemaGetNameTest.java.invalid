package org.springframework.ai.openai.api;import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNull;
import java.util.Map;
import java.util.Objects;
import com.fasterxml.jackson.annotation.JsonInclude;
import com.fasterxml.jackson.annotation.JsonInclude.Include;
import com.fasterxml.jackson.annotation.JsonProperty;
import org.springframework.ai.model.ModelOptionsUtils;
import org.springframework.util.StringUtils;

public class JsonSchemaGetNameTest {
    @Test
    @Tag("valid")
    public void getNameReturnsValidName() {
        // Arrange
        JsonSchema jsonSchema = new JsonSchema("ValidName", null, null);
        
        // Act
        String actualName = jsonSchema.getName();
        
        // Assert
        assertEquals("ValidName", actualName);
    }
    @Test
    @Tag("invalid")
    public void getNameReturnsNullWhenNameIsNull() {
        // Arrange
        JsonSchema jsonSchema = new JsonSchema(null, null, null);
        
        // Act
        String actualName = jsonSchema.getName();
        
        // Assert
        assertNull(actualName);
    }
    @Test
    @Tag("boundary")
    public void getNameReturnsEmptyStringWhenNameIsEmpty() {
        // Arrange
        JsonSchema jsonSchema = new JsonSchema("", null, null);
        
        // Act
        String actualName = jsonSchema.getName();
        
        // Assert
        assertEquals("", actualName);
    }
    @Test
    @Tag("valid")
    public void getNameHandlesSpecialCharacters() {
        // Arrange
        JsonSchema jsonSchema = new JsonSchema("!@#$%^&*()_+", null, null);
        
        // Act
        String actualName = jsonSchema.getName();
        
        // Assert
        assertEquals("!@#$%^&*()_+", actualName);
    }
    @Test
    @Tag("boundary")
    public void getNameHandlesLongName() {
        // Arrange
        String longName = "a".repeat(1000); // Adjust length if needed
        JsonSchema jsonSchema = new JsonSchema(longName, null, null);
        
        // Act
        String actualName = jsonSchema.getName();
        
        // Assert
        assertEquals(longName, actualName);
    }
}