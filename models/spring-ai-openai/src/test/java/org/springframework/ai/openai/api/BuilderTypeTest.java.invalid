package org.springframework.ai.openai.api;import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.mockito.Mockito;
import org.junit.jupiter.api.*;
import java.util.Map;
import java.util.Objects;
import com.fasterxml.jackson.annotation.JsonInclude;
import com.fasterxml.jackson.annotation.JsonInclude.Include;
import com.fasterxml.jackson.annotation.JsonProperty;
import org.springframework.ai.model.ModelOptionsUtils;
import org.springframework.util.StringUtils;

public class BuilderTypeTest {
    @Test
    @Tag("valid")
    public void setValidType() {
        // Arrange
        ResponseFormat.Builder builder = ResponseFormat.builder();
        Object validType = Mockito.mock(Object.class); // Mocking Object instead of Type
        // Act
        ResponseFormat.Builder returnedBuilder = builder.type((Type) validType); // Type casting to Type
        ResponseFormat responseFormat = returnedBuilder.build();
        // Assert
        assertSame(builder, returnedBuilder, "Builder instance should be the same for method chaining");
        assertEquals(validType, responseFormat.getType(), "Type should be set correctly in ResponseFormat");
    }
    @Test
    @Tag("invalid")
    public void setNullType() {
        // Arrange
        ResponseFormat.Builder builder = ResponseFormat.builder();
        // Act
        ResponseFormat.Builder returnedBuilder = builder.type(null);
        ResponseFormat responseFormat = returnedBuilder.build();
        // Assert
        assertSame(builder, returnedBuilder, "Builder instance should be the same for method chaining");
        assertNull(responseFormat.getType(), "Type should be null in ResponseFormat");
    }
    @Test
    @Tag("valid")
    public void methodChainingWithType() {
        // Arrange
        ResponseFormat.Builder builder = ResponseFormat.builder();
        Object validType = Mockito.mock(Object.class); // Mocking Object instead of Type
        Object jsonSchema = Mockito.mock(Object.class); // Mocking Object instead of JsonSchema
        // Act
        ResponseFormat.Builder returnedBuilder = builder.type((Type) validType).jsonSchema((JsonSchema) jsonSchema); // Type casting
        ResponseFormat responseFormat = returnedBuilder.build();
        // Assert
        assertEquals(validType, responseFormat.getType(), "Type should be set correctly in ResponseFormat");
        assertEquals(jsonSchema, responseFormat.getJsonSchema(), "JsonSchema should be set correctly in ResponseFormat");
    }
    @Test
    @Tag("boundary")
    public void typeConsistencyAfterMultipleCalls() {
        // Arrange
        ResponseFormat.Builder builder = ResponseFormat.builder();
        Object firstType = Mockito.mock(Object.class); // Mocking Object instead of Type
        Object secondType = Mockito.mock(Object.class); // Mocking another Object instead of Type
        // Act
        builder.type((Type) firstType); // Type casting
        ResponseFormat.Builder returnedBuilder = builder.type((Type) secondType); // Type casting
        ResponseFormat responseFormat = returnedBuilder.build();
        // Assert
        assertEquals(secondType, responseFormat.getType(), "Type should be the last set Type in ResponseFormat");
    }
    @Test
    @Tag("valid")
    public void typeMethodReturnType() {
        // Arrange
        ResponseFormat.Builder builder = ResponseFormat.builder();
        Object anyType = Mockito.mock(Object.class); // Mocking Object instead of Type
        // Act
        ResponseFormat.Builder returnedBuilder = builder.type((Type) anyType); // Type casting
        // Assert
        assertInstanceOf(ResponseFormat.Builder.class, returnedBuilder, "Returned object should be an instance of Builder");
    }
}