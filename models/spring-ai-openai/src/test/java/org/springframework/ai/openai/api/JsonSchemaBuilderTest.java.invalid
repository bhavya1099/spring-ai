package org.springframework.ai.openai.api;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import java.util.Map;
import java.util.Objects;
import com.fasterxml.jackson.annotation.JsonInclude;
import com.fasterxml.jackson.annotation.JsonInclude.Include;
import com.fasterxml.jackson.annotation.JsonProperty;
import org.springframework.ai.model.ModelOptionsUtils;
import org.springframework.util.StringUtils;

public class JsonSchemaBuilderTest {
    @Test
    @Tag("valid")
    public void verifyBuilderInitialization() {
        // Act
        JsonSchema.Builder builder = JsonSchema.builder();
        // Assert
        assertNotNull(builder, "Builder instance should not be null");
        assertTrue(builder instanceof JsonSchema.Builder, "Returned object should be an instance of JsonSchema.Builder");
    }
    @Test
    @Tag("valid")
    public void verifyBuilderMethodChainability() {
        // Arrange
        JsonSchema.Builder builder = JsonSchema.builder();
        // Act & Assert
        assertSame(builder, builder.name("TestName"), "Method should return the same Builder instance");
        assertSame(builder, builder.schema("TestSchema"), "Method should return the same Builder instance");
        assertSame(builder, builder.strict(true), "Method should return the same Builder instance");
    }
    @Test
    @Tag("valid")
    public void verifyBuilderConfigurationOfJsonSchema() {
        // Arrange
        String expectedName = "TestName";
        String expectedSchema = "TestSchema";
        Boolean expectedStrict = true;
        // Act
        JsonSchema jsonSchema = JsonSchema.builder()
                .name(expectedName)
                .schema(expectedSchema)
                .strict(expectedStrict)
                .build();
        // Assert
        assertEquals(expectedName, jsonSchema.getName(), "JsonSchema name should match the expected value");
        assertEquals(expectedSchema, jsonSchema.getSchema(), "JsonSchema schema should match the expected value");
        assertEquals(expectedStrict, jsonSchema.getStrict(), "JsonSchema strict should match the expected value");
    }
    @Test
    @Tag("boundary")
    public void verifyBuilderDefaultValues() {
        // Act
        JsonSchema jsonSchema = JsonSchema.builder().build();
        // Assert
        assertNull(jsonSchema.getName(), "Default name should be null");
        assertNull(jsonSchema.getSchema(), "Default schema should be null");
        assertNull(jsonSchema.getStrict(), "Default strict should be null");
    }
    @Test
    @Tag("invalid")
    public void verifyBuilderHandlingOfNullValues() {
        // Act
        JsonSchema jsonSchema = JsonSchema.builder()
                .name(null)
                .schema(null)
                .strict(null)
                .build();
        // Assert
        assertNull(jsonSchema.getName(), "Name should be null when set to null");
        assertNull(jsonSchema.getSchema(), "Schema should be null when set to null");
        assertNull(jsonSchema.getStrict(), "Strict should be null when set to null");
    }
}