package org.springframework.ai.openai.api;import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;
import org.junit.jupiter.api.*;
import java.util.Map;
import java.util.Objects;
import com.fasterxml.jackson.annotation.JsonInclude;
import com.fasterxml.jackson.annotation.JsonInclude.Include;
import com.fasterxml.jackson.annotation.JsonProperty;
import org.springframework.ai.model.ModelOptionsUtils;
import org.springframework.util.StringUtils;

public class ResponseFormatGetJsonSchemaTest {
    @Test
    @Tag("valid")
    public void retrieveDefaultJsonSchemaWhenNotSet() {
        // Arrange
        ResponseFormat responseFormat = new ResponseFormat();
        // Act
        Object result = responseFormat.getJsonSchema();
        // Assert
        assertNull(result, "Expected JsonSchema to be null when not set.");
    }
    @Test
    @Tag("valid")
    public void retrieveJsonSchemaAfterBeingSet() {
        // Arrange
        ResponseFormat responseFormat = new ResponseFormat();
        Object expectedSchema = JsonSchema.builder().schema("testSchema").build();
        responseFormat.setJsonSchema((JsonSchema) expectedSchema);
        // Act
        Object result = responseFormat.getJsonSchema();
        // Assert
        assertEquals(expectedSchema, result, "Expected JsonSchema to match the one that was set.");
    }
    @Test
    @Tag("valid")
    public void retrieveJsonSchemaAfterSettingSchemaString() {
        // Arrange
        String schemaString = "testSchemaString";
        ResponseFormat responseFormat = new ResponseFormat(null, schemaString);
        // Act
        Object result = responseFormat.getJsonSchema();
        // Assert
        assertNotNull(result, "Expected JsonSchema not to be null after setting schema string.");
        // Commented out as getSchema() is not defined in JsonSchema
        // assertEquals(schemaString, ((JsonSchema) result).getSchema().get("schema"), "Expected schema string to match.");
    }
    @Test
    @Tag("valid")
    public void retrieveJsonSchemaAfterModifyingType() {
        // Arrange
        ResponseFormat responseFormat = new ResponseFormat();
        Object expectedSchema = JsonSchema.builder().schema("testSchema").build();
        responseFormat.setJsonSchema((JsonSchema) expectedSchema);
        // Commented out as Type is not defined
        // responseFormat.setType(Type.JSON); 
        // Act
        Object result = responseFormat.getJsonSchema();
        // Assert
        assertEquals(expectedSchema, result, "Expected JsonSchema to remain unchanged after modifying type.");
    }
    @Test
    @Tag("integration")
    public void retrieveJsonSchemaAfterUsingBuilder() {
        // Arrange
        Object expectedSchema = JsonSchema.builder().schema("builderSchema").build();
        ResponseFormat responseFormat = new ResponseFormat(null, (JsonSchema) expectedSchema);
        // Act
        Object result = responseFormat.getJsonSchema();
        // Assert
        assertEquals(expectedSchema, result, "Expected JsonSchema to match the one set using the builder.");
    }
}