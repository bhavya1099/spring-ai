package org.springframework.ai.openai.aot;import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import org.mockito.Mockito;
import org.springframework.aot.hint.RuntimeHints;
import org.springframework.aot.hint.TypeReference;
import java.util.Collections;
import java.util.Set;
import static org.junit.jupiter.api.Assertions.assertDoesNotThrow;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;
import org.springframework.ai.openai.api.OpenAiApi;
import org.springframework.ai.openai.api.OpenAiAudioApi;
import org.springframework.ai.openai.api.OpenAiImageApi;
import org.springframework.aot.hint.MemberCategory;
import org.springframework.aot.hint.RuntimeHintsRegistrar;
import org.springframework.lang.NonNull;
import org.springframework.lang.Nullable;
import static org.springframework.ai.aot.AiRuntimeHints.findJsonAnnotatedClassesInPackage;

public class OpenAiRuntimeHintsRegisterHintsTest {
    @Test
    @Tag("valid")
    public void registerHintsWithNullClassLoader() {
        RuntimeHints hints = new RuntimeHints();
        OpenAiRuntimeHints openAiRuntimeHints = new OpenAiRuntimeHints();
        assertDoesNotThrow(() -> openAiRuntimeHints.registerHints(hints, null));
    }
    
    @Test
    @Tag("valid")
    public void registerHintsWithEmptyJsonAnnotatedClasses() {
        RuntimeHints hints = new RuntimeHints();
        OpenAiRuntimeHints openAiRuntimeHints = spy(new OpenAiRuntimeHints());
        // Suggestion: eval method should be made accessible or tested indirectly
        // through public methods that use it.
        doReturn(Collections.emptySet()).when(openAiRuntimeHints).eval(anySet());
        assertDoesNotThrow(() -> openAiRuntimeHints.registerHints(hints, getClass().getClassLoader()));
    }
    
    @Test
    @Tag("valid")
    public void registerHintsWithMultipleJsonAnnotatedClasses() {
        RuntimeHints hints = new RuntimeHints();
        OpenAiRuntimeHints openAiRuntimeHints = spy(new OpenAiRuntimeHints());
        Set<TypeReference> mockTypeReferences = Set.of(
                TypeReference.of("com.example.Class1"),
                TypeReference.of("com.example.Class2")
        );
        // Suggestion: eval method should be made accessible or tested indirectly
        // through public methods that use it.
        doReturn(mockTypeReferences).when(openAiRuntimeHints).eval(anySet());
        assertDoesNotThrow(() -> openAiRuntimeHints.registerHints(hints, getClass().getClassLoader()));
        for (TypeReference tr : mockTypeReferences) {
            verify(hints.reflection(), times(1)).registerType(tr, MemberCategory.values());
        }
    }
    
    @Test
    @Tag("invalid")
    public void registerHintsWithInvalidClassLoader() {
        RuntimeHints hints = new RuntimeHints();
        OpenAiRuntimeHints openAiRuntimeHints = new OpenAiRuntimeHints();
        ClassLoader invalidClassLoader = Mockito.mock(ClassLoader.class);
        assertDoesNotThrow(() -> openAiRuntimeHints.registerHints(hints, invalidClassLoader));
    }
    
    @Test
    @Tag("boundary")
    public void registerHintsWithCustomMemberCategory() {
        RuntimeHints hints = new RuntimeHints();
        OpenAiRuntimeHints openAiRuntimeHints = spy(new OpenAiRuntimeHints());
        Set<TypeReference> mockTypeReferences = Set.of(
                TypeReference.of("com.example.Class1")
        );
        // Suggestion: eval method should be made accessible or tested indirectly
        // through public methods that use it.
        doReturn(mockTypeReferences).when(openAiRuntimeHints).eval(anySet());
        assertDoesNotThrow(() -> openAiRuntimeHints.registerHints(hints, getClass().getClassLoader()));
        for (TypeReference tr : mockTypeReferences) {
            verify(hints.reflection(), times(1)).registerType(tr, MemberCategory.values());
        }
    }
