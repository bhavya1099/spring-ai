import org.springframework.ai.model.ModelOptionsUtils;
import org.springframework.util.StringUtils;

public class ResponseFormatEqualsTest {
    @Test
    @Tag("valid")
    public void equalsWithIdenticalObjects() {
        ResponseFormat responseFormat = new ResponseFormat();
        assertTrue(responseFormat.equals(responseFormat));
    }
    @Test
    @Tag("invalid")
    public void equalsWithNullObject() {
        ResponseFormat responseFormat = new ResponseFormat();
        assertFalse(responseFormat.equals(null));
    }
    @Test
    @Tag("invalid")
    public void equalsWithDifferentClassObject() {
        ResponseFormat responseFormat = new ResponseFormat();
        String differentClassObject = "Different Class Object";
        assertFalse(responseFormat.equals(differentClassObject));
    }
    @Test
    @Tag("valid")
    public void equalsWithEqualObjects() {
        Type type = mock(Type.class);
        JsonSchema jsonSchema = mock(JsonSchema.class);
        ResponseFormat responseFormat1 = new ResponseFormat(type, jsonSchema);
        ResponseFormat responseFormat2 = new ResponseFormat(type, jsonSchema);
        assertTrue(responseFormat1.equals((Object) responseFormat2));
    }
    @Test
    @Tag("invalid")
    public void equalsWithDifferentTypeField() {
        Type type1 = mock(Type.class);
        Type type2 = mock(Type.class);
        JsonSchema jsonSchema = mock(JsonSchema.class);
        ResponseFormat responseFormat1 = new ResponseFormat(type1, jsonSchema);
        ResponseFormat responseFormat2 = new ResponseFormat(type2, jsonSchema);
        assertFalse(responseFormat1.equals((Object) responseFormat2));
    }
    @Test
