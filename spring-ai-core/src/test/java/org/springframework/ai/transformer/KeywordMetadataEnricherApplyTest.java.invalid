    @BeforeEach
    public void setup() {
        mockChatModel = Mockito.mock(ChatModel.class);
        Mockito.when(mockChatModel.call(Mockito.any(Prompt.class))).thenAnswer(invocation -> {
            Prompt prompt = invocation.getArgument(0);
            // Simulate returning text for the mock prompt
            return new Prompt(prompt.getMessages(), prompt.getChatOptions());
        });
        keywordMetadataEnricher = new KeywordMetadataEnricher(mockChatModel, 5);
    }
    @Test
    @Tag("valid")
    public void processValidDocuments() {
        List<Document> documents = new ArrayList<>();
        Document document1 = createMockDocument("Valid text content");
        Document document2 = createMockDocument("Another valid text content");
        documents.add(document1);
        documents.add(document2);
        List<Document> processedDocuments = keywordMetadataEnricher.apply(documents);
        for (Document document : processedDocuments) {
            assertTrue(document.getMetadata().containsKey("excerptKeywords"));
            assertEquals("mockedKeyword1, mockedKeyword2", document.getMetadata().get("excerptKeywords"));
        }
    }
    @Test
    @Tag("invalid")
    public void handleNullInputDocuments() {
        IllegalArgumentException exception = assertThrows(IllegalArgumentException.class, () -> keywordMetadataEnricher.apply(null));
        assertEquals("Documents list must not be null", exception.getMessage());
    }
    @Test
    @Tag("boundary")
    public void processEmptyDocumentList() {
        List<Document> documents = new ArrayList<>();
        List<Document> processedDocuments = keywordMetadataEnricher.apply(documents);
        assertTrue(processedDocuments.isEmpty());
        Mockito.verify(mockChatModel, Mockito.never()).call(Mockito.any(Prompt.class));
    }
    @Test
    @Tag("invalid")
    public void handleNullTextContentInDocuments() {
        Document documentWithNullText = createMockDocument(null);
        List<Document> documents = Collections.singletonList(documentWithNullText);
        IllegalArgumentException exception = assertThrows(IllegalArgumentException.class, () -> keywordMetadataEnricher.apply(documents));
        assertEquals("Document text content must not be null", exception.getMessage());
    }
    @Test
    @Tag("valid")
    public void processMultipleValidDocuments() {
        List<Document> documents = new ArrayList<>();
        documents.add(createMockDocument("Document 1 text"));
        documents.add(createMockDocument("Document 2 text"));
        documents.add(createMockDocument("Document 3 text"));
        List<Document> processedDocuments = keywordMetadataEnricher.apply(documents);
        assertEquals(3, processedDocuments.size());
        for (Document document : processedDocuments) {
            assertTrue(document.getMetadata().containsKey("excerptKeywords"));
            assertEquals("mockedKeyword1, mockedKeyword2", document.getMetadata().get("excerptKeywords"));
        }
    }
    @Test
    @Tag("invalid")
    public void handleKeywordGenerationError() {
        Mockito.when(mockChatModel.call(Mockito.any(Prompt.class)))
               .thenThrow(new RuntimeException("Keyword generation failed"));
        List<Document> documents = Collections.singletonList(createMockDocument("Valid text"));
        RuntimeException exception = assertThrows(RuntimeException.class, () -> keywordMetadataEnricher.apply(documents));
        assertEquals("Keyword generation failed", exception.getMessage());
    }
    @Test
    @Tag("valid")
    public void handleSpecialCharactersInDocumentText() {
        List<Document> documents = Collections.singletonList(createMockDocument("Text content with special characters: !@#$%^&*()"));
        List<Document> processedDocuments = keywordMetadataEnricher.apply(documents);
        assertTrue(processedDocuments.get(0).getMetadata().containsKey("excerptKeywords"));
        assertEquals("mockedKeyword1, mockedKeyword2", processedDocuments.get(0).getMetadata().get("excerptKeywords"));
    }
    @Test
    @Tag("boundary")
    public void verifyPromptTemplateGeneration() {
        List<Document> documents = Collections.singletonList(createMockDocument("Valid text"));
        keywordMetadataEnricher.apply(documents);
        Mockito.verify(mockChatModel).call(Mockito.argThat(prompt ->
                prompt.getMessages() != null // Verifying the prompt input instead of an undefined attribute
        ));
    }
    @Test
    @Tag("integration")
    public void validateConcurrentDocumentProcessing() throws InterruptedException {
        List<Document> documents = createMockDocuments(100);
        Runnable task = () -> keywordMetadataEnricher.apply(documents);
        Thread thread1 = new Thread(task);
        Thread thread2 = new Thread(task);
        thread1.start();
        thread2.start();
        thread1.join();
        thread2.join();
        for (Document document : documents) {
            assertTrue(document.getMetadata().containsKey("excerptKeywords"));
            assertEquals("mockedKeyword1, mockedKeyword2", document.getMetadata().get("excerptKeywords"));
        }
    }
    @Test
    @Tag("valid")
    public void ensureMetadataKeyIsolation() {
        Document documentWithMetadata = createMockDocument("Valid text");
        Map<String, String> existingMetadata = new HashMap<>();
        existingMetadata.put("existingKey", "existingValue");
        documentWithMetadata.getMetadata().putAll(existingMetadata);
        List<Document> processedDocuments = keywordMetadataEnricher.apply(Collections.singletonList(documentWithMetadata));
        assertEquals("existingValue", processedDocuments.get(0).getMetadata().get("existingKey"));
        assertEquals("mockedKeyword1, mockedKeyword2", processedDocuments.get(0).getMetadata().get("excerptKeywords"));
    }
    @Test
    @Tag("boundary")
    public void processLargeDocumentText() {
        String largeText = "Lorem ipsum ".repeat(5000);
        List<Document> documents = Collections.singletonList(createMockDocument(largeText));
        List<Document> processedDocuments = keywordMetadataEnricher.apply(documents);
        assertTrue(processedDocuments.get(0).getMetadata().containsKey("excerptKeywords"));
        assertEquals("mockedKeyword1, mockedKeyword2", processedDocuments.get(0).getMetadata().get("excerptKeywords"));
    }
    @Test
    @Tag("valid")
    public void validateStaticConstantUsage() {
        List<Document> documents = Collections.singletonList(createMockDocument("Valid text"));
        keywordMetadataEnricher.apply(documents);
        Mockito.verify(mockChatModel).call(Mockito.argThat(prompt ->
                prompt.getMessages() != null // Check messages usage instead of undefined method
        ));
    }
    // Helper Methods
    private Document createMockDocument(String textContent) {
        Document document = Mockito.mock(Document.class);
        Mockito.when(document.getText()).thenReturn(textContent);
        Mockito.when(document.getMetadata()).thenReturn(new HashMap<>());
        return document;
    }
    private List<Document> createMockDocuments(int count) {
        List<Document> documents = new ArrayList<>();
        for (int i = 0; i < count; i++) {
            documents.add(createMockDocument("Document " + i + " text"));
        }
        return documents;
    }
}