    }
    @Test
    @Tag("invalid")
    public void applyWithNullInput() {
        ChatModel mockChatModel = mock(ChatModel.class);
        SummaryMetadataEnricher enricher = new SummaryMetadataEnricher(mockChatModel, new ArrayList<>());
        try {
            enricher.apply(null);
        } catch (IllegalArgumentException | NullPointerException e) {
            Assert.isTrue(e.getMessage() != null, "Exception message must describe the issue");
        }
    }
    @Test
    @Tag("integration")
    public void applyWhenChatModelFails() {
        Document document = mock(Document.class);
        when(document.getFormattedContent(MetadataMode.ALL)).thenReturn("formattedContent");
        ChatModel mockChatModel = mock(ChatModel.class);
        when(mockChatModel.call(any(Prompt.class))).thenThrow(new IllegalStateException("Chat model failure"));
        SummaryMetadataEnricher enricher = new SummaryMetadataEnricher(mockChatModel, new ArrayList<>());
        try {
            enricher.apply(List.of(document));
        } catch (IllegalStateException e) {
            Assert.isTrue(e.getMessage().contains("Chat model failure"), "Exception handling failed");
        }
    }
    @Test
    @Tag("boundary")
    public void applyWithLargeDocumentSummaries() {
        Document document = mock(Document.class);
        String largeContent = "LargeContent".repeat(1000); // Simulate large content
        when(document.getFormattedContent(MetadataMode.ALL)).thenReturn(largeContent);
        ChatModel mockChatModel = mock(ChatModel.class);
        Prompt.Result mockResult = mock(Prompt.Result.class);
        Prompt.Output mockOutput = mock(Prompt.Output.class);
        when(mockChatModel.call(any(Prompt.class))).thenReturn(mockResult);
        when(mockResult.getOutput()).thenReturn(mockOutput);
        when(mockOutput.getText()).thenReturn("LargeSummary".repeat(500));
        SummaryMetadataEnricher enricher = new SummaryMetadataEnricher(
                mockChatModel, List.of(SummaryType.CURRENT)
        );
        List<Document> enrichedDocuments = enricher.apply(List.of(document));
        verify(mockChatModel).call(any(Prompt.class));
        // TODO Validate performance behavior for large summaries if test infrastructure supports profiling
    }
