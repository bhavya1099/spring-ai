        Prompt.Output mockOutput = mock(Prompt.Output.class);
        when(mockChatModel.call(any(Prompt.class))).thenReturn(mockResult);
        when(mockResult.getOutput()).thenReturn(mockOutput);
        when(mockOutput.getText()).thenReturn("summary1", "summary2");
        SummaryMetadataEnricher enricher = new SummaryMetadataEnricher(
                mockChatModel,
                List.of(SummaryType.CURRENT, SummaryType.PREVIOUS, SummaryType.NEXT)
        );
        List<Document> enrichedDocuments = enricher.apply(List.of(doc1, doc2));
