import org.springframework.ai.document.DocumentTransformer;
import org.springframework.util.CollectionUtils;

public class SummaryMetadataEnricherApplyTest {
    private static final String CONTEXT_STR_PLACEHOLDER = "context_str";
    private static final String SECTION_SUMMARY_METADATA_KEY = "section_summary";
    private static final String PREV_SECTION_SUMMARY_METADATA_KEY = "prev_section_summary";
    private static final String NEXT_SECTION_SUMMARY_METADATA_KEY = "next_section_summary";
    @Test
    @Tag("valid")
    public void applyWithEmptyDocumentList() {
        List<Document> emptyDocumentList = new ArrayList<>();
        ChatModel mockChatModel = mock(ChatModel.class);
        SummaryMetadataEnricher enricher = new SummaryMetadataEnricher(mockChatModel, new ArrayList<>());
        List<Document> enrichedDocuments = enricher.apply(emptyDocumentList);
        Assert.isTrue(enrichedDocuments.isEmpty(), "Returned document list should be empty");
    }
