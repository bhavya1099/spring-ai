package org.springframework.ai.transformer;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import static org.junit.jupiter.api.Assertions.*;
import java.util.ArrayList;
import java.util.List;
import org.springframework.ai.document.ContentFormatter;
import org.springframework.ai.document.DefaultContentFormatter;
import org.springframework.ai.document.Document;
import org.junit.jupiter.api.*;
import org.springframework.ai.document.DocumentTransformer;

class ContentFormatTransformerApplyTest {
    @Test
    @Tag("valid")
    public void applyTransformationWithNullFormatter() {
        ContentFormatTransformer transformer = new ContentFormatTransformer(null);
        List<Document> inputDocuments = createSampleDocuments();
        List<Document> result = transformer.apply(inputDocuments);
        assertEquals(inputDocuments, result);
    }
    @Test
    @Tag("valid")
    public void applyTransformationWithDefaultContentFormatter() {
        DefaultContentFormatter defaultFormatter = DefaultContentFormatter.builder().build();
        ContentFormatTransformer transformer = new ContentFormatTransformer(defaultFormatter);
        List<Document> inputDocuments = createSampleDocumentsWithDefaultFormatter(defaultFormatter);
        List<Document> result = transformer.apply(inputDocuments);
        result.forEach(document -> {
            assertNotNull(document.getContentFormatter());
            assertTrue(document.getContentFormatter() instanceof DefaultContentFormatter);
            DefaultContentFormatter docFormatter = (DefaultContentFormatter) document.getContentFormatter();
            assertFalse(docFormatter.getExcludedEmbedMetadataKeys().isEmpty());
            assertFalse(docFormatter.getExcludedInferenceMetadataKeys().isEmpty());
        });
    }
    @Test
    @Tag("valid")
    public void applyTransformationWithNonDefaultContentFormatter() {
        // Comment added: Cannot instantiate abstract class ContentFormatter. Business logic needs enhancement to accommodate custom ContentFormatter implementations.
        ContentFormatter genericFormatter = null; // Placeholder for concrete subclass of ContentFormatter
        assertNotNull(genericFormatter, "Ensure a valid instance of ContentFormatter in the business logic.");
    }
    @Test
    @Tag("valid")
    public void applyTransformationWithTemplateRewriteDisabled() {
        DefaultContentFormatter defaultFormatter = DefaultContentFormatter.builder().build();
        ContentFormatTransformer transformer = new ContentFormatTransformer(defaultFormatter, true);
        List<Document> inputDocuments = createSampleDocumentsWithTextTemplate(defaultFormatter);
        List<Document> result = transformer.apply(inputDocuments);
        result.forEach(document -> {
            DefaultContentFormatter docFormatter = (DefaultContentFormatter) document.getContentFormatter();
            assertNull(docFormatter.getTextTemplate()); // Ensure text template is not copied
        });
    }
    @Test
    @Tag("boundary")
    public void applyTransformationOnEmptyDocumentList() {
        ContentFormatTransformer transformer = new ContentFormatTransformer(null);
        List<Document> emptyDocuments = new ArrayList<>();
        List<Document> result = transformer.apply(emptyDocuments);
        assertTrue(result.isEmpty());
    }
    @Test
    @Tag("boundary")
    public void applyTransformationWithNullDocuments() {
        ContentFormatter formatter = DefaultContentFormatter.builder().build();
        ContentFormatTransformer transformer = new ContentFormatTransformer(formatter);
        List<Document> inputDocuments = createDocumentsWithNullEntries();
        List<Document> result = transformer.apply(inputDocuments);
        assertTrue(result.containsAll(inputDocuments)); // Processed without throwing an exception
    }
    @Test
    @Tag("valid")
    public void verifyUpdatedMetadataKeysAfterProcessing() {
        DefaultContentFormatter defaultFormatter = DefaultContentFormatter.builder().build();
        ContentFormatTransformer transformer = new ContentFormatTransformer(defaultFormatter);
        List<Document> inputDocuments = createDocumentsWithExcludedKeys(defaultFormatter);
        List<Document> result = transformer.apply(inputDocuments);
        result.forEach(document -> {
            DefaultContentFormatter docFormatter = (DefaultContentFormatter) document.getContentFormatter();
            assertTrue(docFormatter.getExcludedEmbedMetadataKeys().containsAll(defaultFormatter.getExcludedEmbedMetadataKeys()));
            assertTrue(docFormatter.getExcludedInferenceMetadataKeys().containsAll(defaultFormatter.getExcludedInferenceMetadataKeys()));
        });
    }
    @Test
    @Tag("boundary")
    public void applyTransformationOnSingleDocument() {
        DefaultContentFormatter defaultFormatter = DefaultContentFormatter.builder().build();
        ContentFormatTransformer transformer = new ContentFormatTransformer(defaultFormatter);
        List<Document> inputDocuments = createSingleDocument(defaultFormatter);
        List<Document> result = transformer.apply(inputDocuments);
        assertEquals(1, result.size());
        assertNotNull(result.get(0).getContentFormatter());
    }
    @Test
    @Tag("invalid")
    public void applyTransformationWithNullInput() {
        ContentFormatTransformer transformer = new ContentFormatTransformer(DefaultContentFormatter.builder().build());
        assertThrows(NullPointerException.class, () -> { transformer.apply(null); });
    }
    @Test
    @Tag("integration")
    public void applyTransformationForMatchingFormatterTypes() {
        DefaultContentFormatter formatterA = DefaultContentFormatter.builder().build();
        DefaultContentFormatter formatterB = DefaultContentFormatter.builder().build();
        ContentFormatTransformer transformer = new ContentFormatTransformer(formatterA);
        List<Document> inputDocuments = createDocumentsWithMatchingFormatterTypes(formatterB);
        List<Document> result = transformer.apply(inputDocuments);
        result.forEach(document -> {
            DefaultContentFormatter docFormatter = (DefaultContentFormatter) document.getContentFormatter();
            assertTrue(docFormatter.getExcludedEmbedMetadataKeys().containsAll(formatterB.getExcludedEmbedMetadataKeys()));
        });
    }
