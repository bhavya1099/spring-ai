package org.springframework.ai.image;
import java.util.Collections;
import java.util.List;
import java.util.Objects;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertFalse;
import static org.junit.jupiter.api.Assertions.assertTrue;
import org.junit.jupiter.api.*;
import org.springframework.ai.model.ModelRequest;

public class ImagePromptEqualsTest {
    @Test
    @Tag("valid")
    public void equalsSameObject() {
        // Arrange
        List<ImageMessage> messages = Collections.singletonList(new ImageMessage("Test instruction"));
        ImageOptions options = ImageOptionsBuilder.builder()
                .width(100)
                .height(100)
                .n(1)
                .build(); // Use builder pattern for ImageOptions
        ImagePrompt imagePrompt = new ImagePrompt(messages, options);
        // Act
        boolean result = imagePrompt.equals(imagePrompt);
        // Assert
        assertTrue(result);
    }
    @Test
    @Tag("valid")
    public void equalsWithSameValues() {
        // Arrange
        List<ImageMessage> messages1 = Collections.singletonList(new ImageMessage("Test instruction"));
        List<ImageMessage> messages2 = Collections.singletonList(new ImageMessage("Test instruction"));
        ImageOptions options = ImageOptionsBuilder.builder()
                .width(100)
                .height(100)
                .n(1)
                .build(); // Use builder pattern for ImageOptions
        ImagePrompt imagePrompt1 = new ImagePrompt(messages1, options);
        ImagePrompt imagePrompt2 = new ImagePrompt(messages2, options);
        // Act
        boolean result = imagePrompt1.equals(imagePrompt2);
        // Assert
        assertTrue(result);
    }
    @Test
    @Tag("valid")
    public void equalsWithDifferentValues() {
        // Arrange
        List<ImageMessage> messages1 = Collections.singletonList(new ImageMessage("Instruction 1"));
        List<ImageMessage> messages2 = Collections.singletonList(new ImageMessage("Instruction 2"));
        ImageOptions options1 = ImageOptionsBuilder.builder()
                .width(100)
                .height(100)
                .n(1)
                .build(); // Use builder pattern for ImageOptions
        ImageOptions options2 = ImageOptionsBuilder.builder()
                .width(200)
                .height(200)
                .n(2)
                .build(); // Use builder pattern for ImageOptions
        ImagePrompt imagePrompt1 = new ImagePrompt(messages1, options1);
        ImagePrompt imagePrompt2 = new ImagePrompt(messages2, options2);
        // Act
        boolean result = imagePrompt1.equals(imagePrompt2);
        // Assert
        assertFalse(result);
    }
    @Test
    @Tag("invalid")
    public void equalsWithNull() {
        // Arrange
        List<ImageMessage> messages = Collections.singletonList(new ImageMessage("Instruction"));
        ImageOptions options = ImageOptionsBuilder.builder()
                .width(100)
                .height(100)
                .n(1)
                .build(); // Use builder pattern for ImageOptions
        ImagePrompt imagePrompt = new ImagePrompt(messages, options);
        // Act
        boolean result = imagePrompt.equals(null);
        // Assert
        assertFalse(result);
    }
    @Test
    @Tag("invalid")
    public void equalsWithDifferentType() {
        // Arrange
        List<ImageMessage> messages = Collections.singletonList(new ImageMessage("Test instruction"));
        ImageOptions options = ImageOptionsBuilder.builder()
                .width(100)
                .height(100)
                .n(1)
                .build(); // Use builder pattern for ImageOptions
        ImagePrompt imagePrompt = new ImagePrompt(messages, options);
        // Act
        boolean result = imagePrompt.equals(new String("Invalid Type"));
        // Assert
        assertFalse(result);
    }
    @Test
    @Tag("boundary")
    public void equalsWithEmptyMessages() {
        // Arrange
        List<ImageMessage> emptyMessages1 = Collections.emptyList();
        List<ImageMessage> emptyMessages2 = Collections.emptyList();
        ImageOptions options = ImageOptionsBuilder.builder()
                .width(100)
                .height(100)
                .n(1)
                .build(); // Use builder pattern for ImageOptions
        ImagePrompt imagePrompt1 = new ImagePrompt(emptyMessages1, options);
        ImagePrompt imagePrompt2 = new ImagePrompt(emptyMessages2, options);
        // Act
        boolean result = imagePrompt1.equals(imagePrompt2);
        // Assert
        assertTrue(result);
    }
}