package org.springframework.ai.image;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

public class DefaultImageModelOptionsGetResponseFormatTest {
    private ImageOptionsBuilder imageOptionsBuilder = new ImageOptionsBuilder();
    @Test
    @Tag("valid")
    public void validateDefaultResponseFormat() {
        ImageOptionsBuilder.DefaultImageModelOptions defaultImageModelOptions = imageOptionsBuilder.new DefaultImageModelOptions();
        String actualResponseFormat = (String) defaultImageModelOptions.getResponseFormat();
        assertNull(actualResponseFormat, "Expected default responseFormat to be null or uninitialized.");
    }
    @Test
    @Tag("valid")
    public void retrieveSetResponseFormat() {
        ImageOptionsBuilder.DefaultImageModelOptions defaultImageModelOptions = imageOptionsBuilder.new DefaultImageModelOptions();
        defaultImageModelOptions.setResponseFormat("json");
        String actualResponseFormat = (String) defaultImageModelOptions.getResponseFormat();
        assertEquals("json", actualResponseFormat, "Expected responseFormat to match the value set.");
    }
    @Test
    @Tag("boundary")
    public void handleEmptyResponseFormatString() {
        ImageOptionsBuilder.DefaultImageModelOptions defaultImageModelOptions = imageOptionsBuilder.new DefaultImageModelOptions();
        defaultImageModelOptions.setResponseFormat("");
        String actualResponseFormat = (String) defaultImageModelOptions.getResponseFormat();
        assertEquals("", actualResponseFormat, "Expected responseFormat to handle empty strings correctly.");
    }
    @Test
    @Tag("valid")
    public void testResponseFormatWithNullValue() {
        ImageOptionsBuilder.DefaultImageModelOptions defaultImageModelOptions = imageOptionsBuilder.new DefaultImageModelOptions();
        defaultImageModelOptions.setResponseFormat(null);
        String actualResponseFormat = (String) defaultImageModelOptions.getResponseFormat();
        assertNull(actualResponseFormat, "Expected responseFormat to be null when set explicitly to null.");
    }
    @Test
    @Tag("boundary")
    public void validateSpecialCharactersResponseFormat() {
        ImageOptionsBuilder.DefaultImageModelOptions defaultImageModelOptions = imageOptionsBuilder.new DefaultImageModelOptions();
        defaultImageModelOptions.setResponseFormat("@#$%^&*");
        String actualResponseFormat = (String) defaultImageModelOptions.getResponseFormat();
        assertEquals("@#$%^&*", actualResponseFormat, "Expected responseFormat to correctly handle special characters.");
    }
    @Test
    @Tag("boundary")
    public void testLongStringResponseFormat() {
        ImageOptionsBuilder.DefaultImageModelOptions defaultImageModelOptions = imageOptionsBuilder.new DefaultImageModelOptions();
        String longString = "a".repeat(10000); // Ensure long string is valid for testing
        defaultImageModelOptions.setResponseFormat(longString);
        String actualResponseFormat = (String) defaultImageModelOptions.getResponseFormat();
        assertEquals(longString, actualResponseFormat, "Expected responseFormat to correctly handle long strings.");
    }
    @Test
    @Tag("valid")
    public void handleResponseFormatInDifferentLanguages() {
        ImageOptionsBuilder.DefaultImageModelOptions defaultImageModelOptions = imageOptionsBuilder.new DefaultImageModelOptions();
        defaultImageModelOptions.setResponseFormat("格式"); // Chinese character string
        String actualResponseFormat = (String) defaultImageModelOptions.getResponseFormat();
        assertEquals("格式", actualResponseFormat, "Expected responseFormat to correctly handle multi-language strings.");
    }
    @Test
    @Tag("boundary")
    public void validateResponseFormatUpdate() {
        ImageOptionsBuilder.DefaultImageModelOptions defaultImageModelOptions = imageOptionsBuilder.new DefaultImageModelOptions();
        defaultImageModelOptions.setResponseFormat("initial");
        String updatedResponseFormat1 = (String) defaultImageModelOptions.getResponseFormat();
        assertEquals("initial", updatedResponseFormat1, "Expected responseFormat to initially match the first value set.");
        defaultImageModelOptions.setResponseFormat("updated");
        String updatedResponseFormat2 = (String) defaultImageModelOptions.getResponseFormat();
        assertEquals("updated", updatedResponseFormat2, "Expected responseFormat to match the updated value set.");
    }
}