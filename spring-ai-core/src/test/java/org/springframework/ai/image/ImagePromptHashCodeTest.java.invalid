package org.springframework.ai.image;
import static org.junit.jupiter.api.Assertions.*;
import java.util.Collections;
import java.util.List;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.*;
import java.util.Objects;
import org.springframework.ai.model.ModelRequest;

public class ImagePromptHashCodeTest {
    @Test
    @Tag("valid")
    public void hashCodeWithNullFields() {
        // Arrange
        ImagePrompt prompt = new ImagePrompt((List<ImageMessage>) null);
        // Act
        int hashCodeResult = prompt.hashCode();
        // Assert
        assertTrue(hashCodeResult != 0, "Hash code should produce a valid integer");
    }
    @Test
    @Tag("boundary")
    public void hashCodeWithEmptyMessages() {
        // Arrange
        ImagePrompt prompt = new ImagePrompt(Collections.emptyList());
        // Act
        int hashCodeResult = prompt.hashCode();
        // Assert
        assertTrue(hashCodeResult != 0, "Hash code should produce a valid integer for empty messages");
    }
    @Test
    @Tag("valid")
    public void hashCodeWithValidFields() {
        // Arrange
        ImageMessage imageMessage = new ImageMessage("Instruction1", 1.5f);
        ImageOptionsBuilder builder = ImageOptionsBuilder.builder(); // Using builder to correctly set up ImageOptions
        builder.setN(1);
        builder.setModel("model");
        builder.setWidth(256);
        builder.setHeight(256);
        builder.setResponseFormat("format");
        builder.setStyle("style");
        ImageOptions imageOptions = builder.build();
        ImagePrompt prompt = new ImagePrompt(Collections.singletonList(imageMessage), imageOptions);
        // Act
        int hashCodeResult = prompt.hashCode();
        // Assert
        assertTrue(hashCodeResult != 0, "Hash code should produce a valid integer");
    }
    @Test
    @Tag("invalid")
    public void hashCodeWithNullMessagesAndOptions() {
        // Arrange
        ImagePrompt prompt = new ImagePrompt((List<ImageMessage>) null, null);
        // Act
        int hashCodeResult = prompt.hashCode();
        // Assert
        assertTrue(hashCodeResult != 0, "Hash code should handle null messages and imageModelOptions without exception");
    }
    @Test
    @Tag("integration")
    public void hashCodeConsistencyTest() {
        // Arrange
        ImageMessage message = new ImageMessage("Instruction", 2.0f);
        ImageOptionsBuilder builder = ImageOptionsBuilder.builder(); // Using builder to correctly set up ImageOptions
        builder.setN(1);
        builder.setModel("model");
        builder.setWidth(512);
        builder.setHeight(512);
        builder.setResponseFormat("format");
        builder.setStyle("style");
        ImageOptions options = builder.build();
        ImagePrompt prompt1 = new ImagePrompt(Collections.singletonList(message), options);
        ImagePrompt prompt2 = new ImagePrompt(Collections.singletonList(message), options);
        // Act
        int hashCodeResult1 = prompt1.hashCode();
        int hashCodeResult2 = prompt2.hashCode();
        // Assert
        assertEquals(hashCodeResult1, hashCodeResult2, "Hash codes for identical objects should be consistent");
    }
}