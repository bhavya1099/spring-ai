    public void getDefaultWidthWhenNotSet() {
        // Arrange
        ImageOptionsBuilder imageOptionsBuilder = ImageOptionsBuilder.builder();
        ImageOptions options = imageOptionsBuilder.build();
        // Providing meaningful initialization for DefaultImageModelOptions
