package org.springframework.ai.model.observation;
import io.micrometer.observation.Observation.Context;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import org.mockito.Mockito;
import io.micrometer.tracing.Tracer;
import io.micrometer.tracing.handler.TracingObservationHandler.TracingContext;
import java.util.List;
import java.util.function.Consumer;
import org.junit.jupiter.api.*;
import io.micrometer.observation.Observation;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.util.Assert;
import io.micrometer.observation.ObservationHandler;

public class ErrorLoggingObservationHandlerOnErrorTest {
    @Test
    @Tag("invalid")
    public void onErrorWithNullContext() {
        Consumer<Context> mockErrorConsumer = Mockito.mock(Consumer.class);
        Tracer mockTracer = Mockito.mock(Tracer.class);
        ErrorLoggingObservationHandler handler = new ErrorLoggingObservationHandler(mockTracer, List.of(), mockErrorConsumer);
        handler.onError(null);
        Mockito.verifyNoInteractions(mockErrorConsumer);
    }
    @Test
    @Tag("valid")
    public void onErrorWithTracingContext() {
        Context mockContext = Mockito.mock(Context.class);
        TracingContext mockTracingContext = Mockito.mock(TracingContext.class);
        Tracer mockTracer = Mockito.mock(Tracer.class);
        Consumer<Context> mockErrorConsumer = Mockito.mock(Consumer.class);
        Mockito.when(mockContext.get(TracingContext.class)).thenReturn(mockTracingContext);
        Mockito.when(mockTracingContext.getSpan()).thenReturn(Mockito.mock(io.micrometer.tracing.Span.class));
        
        ErrorLoggingObservationHandler handler = new ErrorLoggingObservationHandler(mockTracer, List.of(TracingContext.class), mockErrorConsumer);
        handler.onError(mockContext);
        Mockito.verify(mockTracer).withSpan(Mockito.any(io.micrometer.tracing.Span.class)); 
        Mockito.verify(mockErrorConsumer).accept(mockContext);
    }
