package org.springframework.ai.model.observation;
import org.junit.jupiter.api.*;
import org.springframework.ai.observation.ModelObservationContext;
import org.springframework.ai.observation.AiOperationMetadata;
import org.springframework.lang.Nullable;
import static org.junit.jupiter.api.Assertions.*;
import io.micrometer.observation.Observation;
import org.springframework.util.Assert;

@Tag("valid")
@DisplayName("ModelObservationContext GetRequest Tests")
class ModelObservationContextGetRequestTest extends Observation.Context {
    @Test
    @Tag("valid")
    @DisplayName("Test Null Initialization of 'request' Field in ModelObservationContext")
    public void validateNullInitializationOfRequest() {
        // Arrange
        AiOperationMetadata metadata = new AiOperationMetadata("providerName", "operationType");
        ModelObservationContext<String, String> modelObservationContext = new ModelObservationContext<>(null, metadata);
        // Act
        String request = modelObservationContext.getRequest();
        // Assert
        assertNull(request, "The 'request' field should be initialized to null by default.");
    }
    @Test
    @Tag("valid")
    @DisplayName("Test 'request' Field with Valid Input")
    public void validateRequestFieldWithValidInput() {
        // Arrange
        AiOperationMetadata metadata = new AiOperationMetadata("providerName", "operationType");
        String validRequest = "Valid request";
        ModelObservationContext<String, String> modelObservationContext = new ModelObservationContext<>(validRequest, metadata);
        // Act
        String request = modelObservationContext.getRequest();
        // Assert
        assertEquals(validRequest, request, "The 'request' field should return the same value as provided during initialization.");
    }
    @Test
    @Tag("invalid")
    @DisplayName("Test Exception Handling for Null Metadata Initialization")
    public void validateExceptionForNullMetadata() {
        // Expect IllegalArgumentException on null AiOperationMetadata
        Exception exception = assertThrows(IllegalArgumentException.class, () -> {
            new ModelObservationContext<>("Valid request", null);
        });
        assertEquals("operationMetadata cannot be null", exception.getMessage(), "Expected exception message for null metadata.");
    }
    @Test
    @Tag("invalid")
    @DisplayName("Test Exception Handling for Null Request Initialization")
    public void validateExceptionForNullRequest() {
        // Arrange
        AiOperationMetadata metadata = new AiOperationMetadata("providerName", "operationType");
        // Expect IllegalArgumentException on null request
        Exception exception = assertThrows(IllegalArgumentException.class, () -> {
            new ModelObservationContext<>(null, metadata);
        });
        assertEquals("request cannot be null", exception.getMessage(), "Expected exception message for null request.");
    }
}