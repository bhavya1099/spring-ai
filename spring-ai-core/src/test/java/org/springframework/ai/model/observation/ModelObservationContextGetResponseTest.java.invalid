package org.springframework.ai.model.observation;
import io.micrometer.observation.Observation;
import org.springframework.ai.observation.AiOperationMetadata;
import org.springframework.lang.Nullable;
import org.springframework.util.Assert;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

class ModelObservationContextGetResponseTest extends Observation.Context {
    @Test
    @Tag("valid")
    public void responseIsNullByDefault() {
        // Arrange
        AiOperationMetadata operationMetadata = new AiOperationMetadata("operationTypeValue", "providerValue");
        Object request = new Object();
        ModelObservationContext<Object, Object> context = new ModelObservationContext<>(request, operationMetadata);
        // Act
        @Nullable Object actualResponse = context.getResponse();
        // Assert
        assertNull(actualResponse);
    }
    @Test
    @Tag("valid")
    public void setResponseAndVerify() {
        // Arrange
        AiOperationMetadata operationMetadata = new AiOperationMetadata("operationTypeValue", "providerValue");
        Object request = new Object();
        ModelObservationContext<Object, Object> context = new ModelObservationContext<>(request, operationMetadata);
        Object expectedResponse = new Object();
        // Act
        context.setResponse(expectedResponse);
        @Nullable Object actualResponse = context.getResponse();
        // Assert
        assertEquals(expectedResponse, actualResponse);
    }
    @Test
    @Tag("invalid")
    public void setResponseThrowsExceptionWhenNull() {
        // Arrange
        AiOperationMetadata operationMetadata = new AiOperationMetadata("operationTypeValue", "providerValue");
        Object request = new Object();
        ModelObservationContext<Object, Object> context = new ModelObservationContext<>(request, operationMetadata);
        // Act & Assert
        Exception exception = assertThrows(IllegalArgumentException.class, () -> context.setResponse(null));
        assertEquals("response cannot be null", exception.getMessage());
    }
}