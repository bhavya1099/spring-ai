@Test
public void streamLogging(CapturedOutput output) {
    given(this.chatModel.stream(this.promptCaptor.capture())).willReturn(Flux.generate(() -> new ChatResponse(List.of(new Generation(new AssistantMessage("Your answer is ZXY")))), (state, sink) -> {
        sink.next(state);
        sink.complete();
        return state;
