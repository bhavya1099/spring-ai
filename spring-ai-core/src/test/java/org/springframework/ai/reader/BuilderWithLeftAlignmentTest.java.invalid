package org.springframework.ai.reader;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertTrue;
import static org.junit.jupiter.api.Assertions.assertEquals;
import org.springframework.util.StringUtils;

public class BuilderWithLeftAlignmentTest {
    @Test
    @Tag("valid")
    public void withLeftAlignmentSetsToTrue() {
        // Arrange: Create a builder and set leftAlignment to true
        ExtractedTextFormatter.Builder builder = new ExtractedTextFormatter.Builder()
            .withLeftAlignment(true);
        // Act: Build the ExtractedTextFormatter object using the builder
        ExtractedTextFormatter extractFormatterTest = builder.build();
        // Assert: Verify that the 'leftAlignment' property is correctly set in the built object
        assertTrue(extractFormatterTest.isLeftAlignment(), "Left alignment should be set to true");
    }
    @Test
    @Tag("valid")
    public void withLeftAlignmentDefaultValue() {
        // Arrange: Create a builder without explicitly setting leftAlignment
        ExtractedTextFormatter.Builder builder = new ExtractedTextFormatter.Builder();
        // Act: Build the ExtractedTextFormatter object using the builder
        ExtractedTextFormatter extractFormatterTest = builder.build();
        // Assert: Verify the default value of 'leftAlignment' 
        assertEquals(false, extractFormatterTest.isLeftAlignment(), "Left alignment default value should be false");
    }
}