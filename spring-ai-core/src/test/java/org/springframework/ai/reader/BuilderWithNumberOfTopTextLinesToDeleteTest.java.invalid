public class BuilderWithNumberOfTopTextLinesToDeleteTest {
    @Test
    @Tag("valid")
    public void setValidNumberOfTopTextLinesToDelete() {
        ExtractedTextFormatter.Builder builder = new ExtractedTextFormatter.Builder();
        int numberOfTopTextLinesToDelete = 5;
        // Use method directly as per the implementation details and defined attributes
        ExtractedTextFormatter.Builder returnedBuilder = builder.withNumberOfTopTextLinesToDelete(numberOfTopTextLinesToDelete);
        // Assertions with proper type casting to match expected values and avoid future errors
        assertEquals((int) numberOfTopTextLinesToDelete, (int) builder.numberOfTopTextLinesToDelete, "The number of top text lines to delete should match the input value");
        assertSame(builder, returnedBuilder, "Returned object should be the same Builder instance");
    }
