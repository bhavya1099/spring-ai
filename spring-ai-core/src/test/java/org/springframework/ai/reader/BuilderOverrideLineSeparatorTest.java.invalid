package org.springframework.ai.reader;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import static org.junit.jupiter.api.Assertions.*;
import org.springframework.util.StringUtils;

class BuilderOverrideLineSeparatorTest {
    @Test
    @Tag("valid")
    public void overrideLineSeparatorSuccessfully() {
        // Arrange
        ExtractedTextFormatter.Builder builder = new ExtractedTextFormatter.Builder();
        String validSeparator = "\n"; // Define valid line separator without ambiguity.
        // Act
        builder.overrideLineSeparator(validSeparator);
        // Assert
        assertEquals((String) validSeparator, builder.lineSeparator, "Line separator should be updated successfully");
    }
    @Test
    @Tag("invalid")
    public void overrideLineSeparatorWithNullValue() {
        // Arrange
        ExtractedTextFormatter.Builder builder = new ExtractedTextFormatter.Builder();
        String invalidSeparator = null; // Define null to test invalid input scenario.
        // Act
        builder.overrideLineSeparator(invalidSeparator);
        // Assert
        assertNull((String) builder.lineSeparator, "Line separator should remain null when overridden with null value");
    }
    @Test
    @Tag("boundary")
    public void overrideLineSeparatorWithEmptyString() {
        // Arrange
        ExtractedTextFormatter.Builder builder = new ExtractedTextFormatter.Builder();
        String emptySeparator = ""; // Define empty separator to test boundary case.
        // Act
        builder.overrideLineSeparator(emptySeparator);
        // Assert
        assertEquals((String) emptySeparator, builder.lineSeparator, "Line separator should be updated to empty string");
    }
}