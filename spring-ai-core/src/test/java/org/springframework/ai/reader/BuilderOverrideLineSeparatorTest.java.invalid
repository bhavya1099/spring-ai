package org.springframework.ai.reader;import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.Tag;
import static org.junit.jupiter.api.Assertions.*;
import org.springframework.util.StringUtils;

public class BuilderOverrideLineSeparatorTest {
    @Test
    @Tag("valid")
    public void overrideLineSeparatorWithValidInput() {
        // Arrange
        ExtractedTextFormatter formatter = new ExtractedTextFormatter.Builder()
                .withLeftAlignment(false) // Example chained setup
                .build(); // Ensure parent class instance is created
        ExtractedTextFormatter.Builder builder = formatter.new Builder(); // Nested Builder setup
        String validLineSeparator = "\n"; // Valid input
        
        // Act
        ExtractedTextFormatter.Builder returnedBuilder = builder.overrideLineSeparator(validLineSeparator);
        // Assert
        assertEquals(validLineSeparator, returnedBuilder.lineSeparator); // Corrected assertion format
        assertDoesNotThrow(() -> builder.validateLineSeparator(validLineSeparator), 
                "Expected no exception for valid lineSeparator.");
        assertNotNull(returnedBuilder, "Returned builder should not be null.");
    }
    @Test
    @Tag("invalid")
    public void overrideLineSeparatorWithNullInput() {
        // Arrange
        ExtractedTextFormatter formatter = new ExtractedTextFormatter.Builder()
                .withLeftAlignment(true) // Example chained setup
                .build(); // Ensure parent class instance is created
        ExtractedTextFormatter.Builder builder = formatter.new Builder(); // Nested Builder setup
        String invalidLineSeparator = null; // Invalid input
        
        // Act & Assert
        assertThrows(IllegalArgumentException.class, () -> builder.overrideLineSeparator(invalidLineSeparator), 
                "Expected IllegalArgumentException for null lineSeparator.");
    }
}