    @Test
    @Tag("valid")
    public void testEmptyJsonNodeArray() {
        JsonNode emptyArray = Mockito.mock(JsonNode.class);
        Mockito.when(emptyArray.isArray()).thenReturn(true);
        Mockito.when(emptyArray.spliterator()).thenReturn(Collections.emptyList().spliterator());
        List<Document> result = jsonReader.get(emptyArray);
        Assertions.assertTrue(result.isEmpty(), "Expected an empty list for empty JsonNode array.");
    }
    
    @Test
    @Tag("valid")
    public void testSingleJsonNodeObject() {
        JsonNode singleNode = Mockito.mock(JsonNode.class);
        Document expectedDocument = Mockito.mock(Document.class);
        Mockito.doReturn(expectedDocument).when(jsonReader).parseJsonNode(singleNode, objectMapper); // Adjusted to match the method visibility
        List<Document> result = jsonReader.get(singleNode);
        Assertions.assertEquals(1, result.size(), "Expected a single Document in the list.");
        Assertions.assertEquals(expectedDocument, result.get(0), "Document contents do not match.");
    }
    
