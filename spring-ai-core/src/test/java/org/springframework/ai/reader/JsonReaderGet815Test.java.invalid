        Mockito.when(arrayNode.spliterator()).thenReturn(List.of(childNode1, childNode2).spliterator());
        Mockito.doReturn(doc1).when(jsonReader).parseJsonNode(childNode1, objectMapper); // Adjusted
        Mockito.doReturn(doc2).when(jsonReader).parseJsonNode(childNode2, objectMapper); // Adjusted
        List<Document> result = jsonReader.get(arrayNode);
        Assertions.assertEquals(2, result.size(), "Expected two converted Documents.");
        Assertions.assertIterableEquals(List.of(doc1, doc2), result, "Document contents do not match.");
    }
    
