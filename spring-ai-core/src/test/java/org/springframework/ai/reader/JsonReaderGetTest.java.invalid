        // Execute and validate
        List<Document> documents = jsonReader.get();
        assertNotNull(documents);
        assertEquals(1, documents.size());
    }
    @Test
    @Tag("invalid")
    public void malformedJsonResource() throws IOException {
        // Mocking input stream and exception handling
        when(resource.getInputStream()).thenReturn(new ByteArrayInputStream("malformed".getBytes()));
        doThrow(IOException.class).when(objectMapper).readTree(any());
        // Execute and validate for exception
