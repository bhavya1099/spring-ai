import com.fasterxml.jackson.core.type.TypeReference;
import org.springframework.ai.document.DocumentReader;

@ExtendWith(MockitoExtension.class)
class JsonReaderGetTest {
    @Mock
    private Resource resource;
    @Mock
    private ObjectMapper objectMapper;
    @Mock
    private JsonMetadataGenerator jsonMetadataGenerator;
    @InjectMocks
    private JsonReader jsonReader;
    @Test
    @Tag("valid")
    public void validJsonResourceWithArrayRootNode() throws IOException {
        String jsonArray = "[{\"key\":\"value1\"}, {\"key\":\"value2\"}]";
        JsonNode mockArrayNode = mock(JsonNode.class);
        JsonNode mockElementNode = mock(JsonNode.class);
        // Mocking input stream and parsing logic
        when(resource.getInputStream()).thenReturn(new ByteArrayInputStream(jsonArray.getBytes()));
        when(objectMapper.readTree(any())).thenReturn(mockArrayNode);
        when(mockArrayNode.isArray()).thenReturn(true);
        when(mockArrayNode.spliterator()).thenReturn(Collections.singleton(mockElementNode).spliterator());
        when(jsonReader.parseJsonNode(mockElementNode, objectMapper)).thenReturn(mock(Document.class));
        // Execute and validate
        List<Document> documents = jsonReader.get();
        assertEquals(1, documents.size());
    }
    @Test
    @Tag("valid")
    public void validJsonResourceWithObjectRootNode() throws IOException {
        String jsonObject = "{\"key\":\"value\"}";
        JsonNode mockObjectNode = mock(JsonNode.class);
        // Mocking input stream and parsing logic
        when(resource.getInputStream()).thenReturn(new ByteArrayInputStream(jsonObject.getBytes()));
        when(objectMapper.readTree(any())).thenReturn(mockObjectNode);
        when(mockObjectNode.isArray()).thenReturn(false);
        when(jsonReader.parseJsonNode(mockObjectNode, objectMapper)).thenReturn(mock(Document.class));
        // Execute and validate
        List<Document> documents = jsonReader.get();
        assertEquals(1, documents.size());
