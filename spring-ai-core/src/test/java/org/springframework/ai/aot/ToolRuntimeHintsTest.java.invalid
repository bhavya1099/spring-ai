package org.springframework.ai.aot;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import org.springframework.aot.hint.RuntimeHints;
import org.springframework.aot.hint.RuntimeHintsRegistrar;
import org.springframework.lang.Nullable;
import org.springframework.ai.tool.execution.DefaultToolCallResultConverter;
import org.junit.jupiter.api.Assertions;
import org.junit.jupiter.api;
import org.springframework.aot.hint.MemberCategory;
import org.springframework.lang.NonNull; 
 public class ToolRuntimeHintsTest {

/*ROOST_METHOD_HASH=registerHints_10ed69d8fc
ROOST_METHOD_SIG_HASH=registerHints_8ed8822dbe

*/public void registerDefaultToolCallResultConverter() {
    
    runtimeHints = new RuntimeHints();
    MemberCategory[] memberCategories = MemberCategory.values();
    
    toolRuntimeHints.registerHints(runtimeHints, null);
    
    for (MemberCategory memberCategory : memberCategories) {
        assertTrue(runtimeHints.reflection().isRegistered(DefaultToolCallResultConverter.class), "DefaultToolCallResultConverter must be registered for reflection!");
    }
}

/*ROOST_METHOD_HASH=registerHints_10ed69d8fc
ROOST_METHOD_SIG_HASH=registerHints_8ed8822dbe

*/public void handleNullClassLoader() {
    
    runtimeHints = new RuntimeHints();
    
    toolRuntimeHints.registerHints(runtimeHints, null);
    
    assertTrue(runtimeHints.reflection().isRegistered(DefaultToolCallResultConverter.class), "DefaultToolCallResultConverter should still be registered for reflection with null ClassLoader.");
}

/*ROOST_METHOD_HASH=registerHints_10ed69d8fc
ROOST_METHOD_SIG_HASH=registerHints_8ed8822dbe

*/public void testEmptyMemberCategoryArray() {
    
    runtimeHints = mock(RuntimeHints.class);
    when(runtimeHints.reflection()).thenReturn(Mockito.mock(RuntimeHints.ReflectionHints.class));
    MemberCategory[] emptyArray = new MemberCategory[0];
    MemberCategory[] originalValues = MemberCategory.values();
    try {
        
        
        MemberCategory.values = () -> emptyArray;
    } catch (UnsupportedOperationException ignored) {
        fail("Attempt to mock MemberCategory.values.");
    }
    
    toolRuntimeHints.registerHints(runtimeHints, null);
    
    verify(runtimeHints.reflection()).registerType(DefaultToolCallResultConverter.class, emptyArray);
    
    MemberCategory.values = originalValues;
}

/*ROOST_METHOD_HASH=registerHints_10ed69d8fc
ROOST_METHOD_SIG_HASH=registerHints_8ed8822dbe

*/public void preExistingReflectionConfiguration() {
    
    runtimeHints = new RuntimeHints();
    runtimeHints.reflection().registerType(String.class, MemberCategory.INVOKE_PUBLIC_METHODS);
    
    toolRuntimeHints.registerHints(runtimeHints, null);
    
    assertTrue(runtimeHints.reflection().isRegistered(String.class), "Pre-existing reflection configuration must remain.");
    assertTrue(runtimeHints.reflection().isRegistered(DefaultToolCallResultConverter.class), "DefaultToolCallResultConverter should be registered for reflection.");
}

/*ROOST_METHOD_HASH=registerHints_10ed69d8fc
ROOST_METHOD_SIG_HASH=registerHints_8ed8822dbe

*/public void handleMultipleClassLoaders() {
    
    runtimeHints = new RuntimeHints();
    ClassLoader customClassLoader = Mockito.mock(ClassLoader.class);
    
    toolRuntimeHints.registerHints(runtimeHints, customClassLoader);
    
    assertTrue(runtimeHints.reflection().isRegistered(DefaultToolCallResultConverter.class), "Registration of DefaultToolCallResultConverter must be unaffected by differing ClassLoader inputs.");
}

/*ROOST_METHOD_HASH=registerHints_10ed69d8fc
ROOST_METHOD_SIG_HASH=registerHints_8ed8822dbe

*/public void validateMemberCategoryUsage() {
    
    runtimeHints = new RuntimeHints();
    MemberCategory[] memberCategories = MemberCategory.values();
    
    toolRuntimeHints.registerHints(runtimeHints, null);
    
    for (MemberCategory category : memberCategories) {
        assertTrue(runtimeHints.reflection().isRegistered(DefaultToolCallResultConverter.class), "All MemberCategory values should be utilized in reflection registration.");
    }
}

/*ROOST_METHOD_HASH=registerHints_10ed69d8fc
ROOST_METHOD_SIG_HASH=registerHints_8ed8822dbe

*/public void handleRuntimeHintsException() {
    
    runtimeHints = mock(RuntimeHints.class);
    RuntimeHints.ReflectionHints reflectionHints = mock(RuntimeHints.ReflectionHints.class);
    when(runtimeHints.reflection()).thenReturn(reflectionHints);
    doThrow(RuntimeException.class).when(reflectionHints).registerType(eq(DefaultToolCallResultConverter.class), any(MemberCategory[].class));
    
    assertDoesNotThrow(() -> toolRuntimeHints.registerHints(runtimeHints, null), "The method should handle exceptions gracefully during reflection registration.");
}

/*ROOST_METHOD_HASH=registerHints_10ed69d8fc
ROOST_METHOD_SIG_HASH=registerHints_8ed8822dbe

*/public void checkReflectionRegistrationValidity() {
    
    runtimeHints = new RuntimeHints();
    
    toolRuntimeHints.registerHints(runtimeHints, null);
    
    assertTrue(runtimeHints.reflection().isRegistered(DefaultToolCallResultConverter.class), "DefaultToolCallResultConverter should be registered for reflection with valid MemberCategory values.");
}

/*ROOST_METHOD_HASH=registerHints_10ed69d8fc
ROOST_METHOD_SIG_HASH=registerHints_8ed8822dbe

*/public void handleNullRuntimeHintsArgument() {
    
    assertThrows(NullPointerException.class, () -> toolRuntimeHints.registerHints(null, ClassLoader.getSystemClassLoader()), "Null RuntimeHints argument should throw a NullPointerException.");
}
} 