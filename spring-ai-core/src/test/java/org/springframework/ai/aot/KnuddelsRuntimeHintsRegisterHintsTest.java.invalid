package org.springframework.ai.aot;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.springframework.aot.hint.RuntimeHints;
import org.springframework.core.io.ClassPathResource;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;
import org.springframework.aot.hint.RuntimeHintsRegistrar;

public class KnuddelsRuntimeHintsRegisterHintsTest {
    @Test
    @Tag("valid")
    public void verifyResourceRegistrationSuccessfully() {
        RuntimeHints runtimeHints = new RuntimeHints();
        KnuddelsRuntimeHints knuddelsRuntimeHints = new KnuddelsRuntimeHints();
        knuddelsRuntimeHints.registerHints(runtimeHints, null);
        assert(runtimeHints.resources().getResourceRegistrations().stream()
                .anyMatch(resourceHint -> resourceHint.getResource().equals(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken"))));
    }
    @Test
    @Tag("valid")
    public void handleNullClassLoaderGracefully() {
        RuntimeHints runtimeHints = new RuntimeHints();
        KnuddelsRuntimeHints knuddelsRuntimeHints = new KnuddelsRuntimeHints();
        knuddelsRuntimeHints.registerHints(runtimeHints, null);
        assert(runtimeHints.resources().getResourceRegistrations().stream()
                .anyMatch(resourceHint -> resourceHint.getResource().equals(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken"))));
    }
    @Test
    @Tag("integration")
    public void registerHintsIntoEmptyRuntimeHints() {
        RuntimeHints runtimeHints = new RuntimeHints();
        KnuddelsRuntimeHints knuddelsRuntimeHints = new KnuddelsRuntimeHints();
        knuddelsRuntimeHints.registerHints(runtimeHints, null);
        assert(runtimeHints.resources().getResourceRegistrations().stream()
                .anyMatch(resourceHint -> resourceHint.getResource().equals(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken"))));
    }
    @Test
    @Tag("integration")
    public void appendResourcesToRuntimeHints() {
        RuntimeHints runtimeHints = new RuntimeHints();
        runtimeHints.resources().registerResource(new ClassPathResource("/existing/resource/path"));
        KnuddelsRuntimeHints knuddelsRuntimeHints = new KnuddelsRuntimeHints();
        knuddelsRuntimeHints.registerHints(runtimeHints, null);
        assert(runtimeHints.resources().getResourceRegistrations().stream()
                .anyMatch(resourceHint -> resourceHint.getResource().equals(new ClassPathResource("/existing/resource/path"))));
        assert(runtimeHints.resources().getResourceRegistrations().stream()
                .anyMatch(resourceHint -> resourceHint.getResource().equals(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken"))));
    }
    @Test
    @Tag("invalid")
    public void handleIncorrectResourcePath() {
        // Comment: The business logic function `registerHints` needs improvement to handle exceptions caused by invalid resource paths gracefully.
        RuntimeHints runtimeHints = mock(RuntimeHints.class);
        when(runtimeHints.resources().getResourceRegistrations())
                .thenThrow(new IllegalArgumentException("Resource path not valid"));
        KnuddelsRuntimeHints knuddelsRuntimeHints = new KnuddelsRuntimeHints();
        try {
            knuddelsRuntimeHints.registerHints(runtimeHints, null);
            assert(false); // Should not reach here, exception expected
        } catch (IllegalArgumentException e) {
            assert(e.getMessage().equals("Resource path not valid"));
        }
    }
    @Test
    @Tag("boundary")
    public void ensureNoAdditionalReflectionHintsRegistered() {
        RuntimeHints runtimeHints = new RuntimeHints();
        KnuddelsRuntimeHints knuddelsRuntimeHints = new KnuddelsRuntimeHints();
        knuddelsRuntimeHints.registerHints(runtimeHints, null);
        assert(runtimeHints.reflection().getReflectionHints().isEmpty());
    }
    @Test
    @Tag("integration")
    public void ensureThreadSafetyDuringResourceRegistration() throws InterruptedException {
        KnuddelsRuntimeHints knuddelsRuntimeHints = new KnuddelsRuntimeHints();
        RuntimeHints[] runtimeHintsArray = new RuntimeHints[10];
        for (int i = 0; i < 10; i++) {
            runtimeHintsArray[i] = new RuntimeHints();
        }
        Runnable task = () -> {
            for (RuntimeHints hints : runtimeHintsArray) {
                knuddelsRuntimeHints.registerHints(hints, null);
            }
        };
        Thread[] threads = new Thread[10];
        for (int i = 0; i < 10; i++) {
            threads[i] = new Thread(task);
            threads[i].start();
        }
        for (int i = 0; i < 10; i++) {
            threads[i].join();
        }
        for (RuntimeHints hints : runtimeHintsArray) {
            assert(hints.resources().getResourceRegistrations().stream()
                    .anyMatch(resourceHint -> resourceHint.getResource().equals(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken"))));
        }
    }
}