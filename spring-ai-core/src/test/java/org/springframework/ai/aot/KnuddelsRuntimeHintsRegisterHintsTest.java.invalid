package org.springframework.ai.aot;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import org.springframework.aot.hint.RuntimeHints;
import org.springframework.aot.hint.RuntimeHintsRegistrar;
import org.springframework.core.io.ClassPathResource;
import static org.junit.jupiter.api.Assertions.assertTrue;

class KnuddelsRuntimeHintsRegisterHintsTest {
    private final KnuddelsRuntimeHints knuddelsRuntimeHints = new KnuddelsRuntimeHints();
    @Test
    @Tag("valid")
    public void registerHintsWithValidClassLoader() {
        // Arrange
        RuntimeHints runtimeHints = new RuntimeHints();
        ClassLoader classLoader = Mockito.mock(ClassLoader.class);
        // Act
        knuddelsRuntimeHints.registerHints(runtimeHints, classLoader);
        // Assert
        assertTrue(runtimeHints.resources().getRegisteredResources().contains(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken")));
    }
    @Test
    @Tag("valid")
    public void registerHintsWithNullClassLoader() {
        // Arrange
        RuntimeHints runtimeHints = new RuntimeHints();
        ClassLoader classLoader = null;
        // Act
        knuddelsRuntimeHints.registerHints(runtimeHints, classLoader);
        // Assert
        assertTrue(runtimeHints.resources().getRegisteredResources().contains(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken")));
    }
    @Test
    @Tag("boundary")
    public void registerHintsWithNonExistentResourcePath() {
        // Arrange
        RuntimeHints runtimeHints = new RuntimeHints();
        ClassLoader classLoader = Mockito.mock(ClassLoader.class);
        ClassPathResource resource = new ClassPathResource("/com/knuddels/non_existent_resource.file");
        // TODO: Update KnuddelsRuntimeHints class to accept dynamic resource paths for testing this scenario
        // Act
        knuddelsRuntimeHints.registerHints(runtimeHints, classLoader);
        // Assert
        // The resource path needs to be dynamically accepted within `KnuddelsRuntimeHints` to validate this test.
        assertTrue(runtimeHints.resources().getRegisteredResources().contains(resource));
    }
    @Test
    @Tag("boundary")
    public void registerHintsWithEmptyRuntimeHintsInstance() {
        // Arrange
        RuntimeHints runtimeHints = new RuntimeHints();
        ClassLoader classLoader = Mockito.mock(ClassLoader.class);
        // Act
        knuddelsRuntimeHints.registerHints(runtimeHints, classLoader);
        // Assert
        assertTrue(runtimeHints.resources().getRegisteredResources().contains(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken")));
    }
    @Test
    @Tag("valid")
    public void registerHintsCalledMultipleTimes() {
        // Arrange
        RuntimeHints runtimeHints = new RuntimeHints();
        ClassLoader classLoader = Mockito.mock(ClassLoader.class);
        // Act
        knuddelsRuntimeHints.registerHints(runtimeHints, classLoader);
        knuddelsRuntimeHints.registerHints(runtimeHints, classLoader);
        // Assert
        assertTrue(runtimeHints.resources().getRegisteredResources().contains(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken")));
    }
    @Test
    @Tag("integration")
    public void registerHintsWithAlternateResourcePaths() {
        // Arrange
        RuntimeHints runtimeHints = new RuntimeHints();
        ClassLoader classLoader = Mockito.mock(ClassLoader.class);
        ClassPathResource alternateResource = new ClassPathResource("/com/knuddels/alternate/resource.file");
        // TODO: Update KnuddelsRuntimeHints class to accept dynamic resource paths for testing this scenario
        // Act
        knuddelsRuntimeHints.registerHints(runtimeHints, classLoader);
        // Assert
        // The alternate resource path needs to be dynamically accepted within `KnuddelsRuntimeHints` to validate this test.
        assertTrue(runtimeHints.resources().getRegisteredResources().contains(alternateResource));
    }
}