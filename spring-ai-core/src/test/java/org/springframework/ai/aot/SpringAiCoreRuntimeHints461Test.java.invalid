package org.springframework.ai.aot;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.springframework.aot.hint.RuntimeHints;
import org.springframework.core.io.ClassPathResource;
import org.springframework.util.ReflectionUtils;
import java.lang.reflect.Method;
import org.junit.jupiter.api.Assertions.assertTrue;
import org.junit.jupiter.api.Assertions.assertNotNull;
import org.springframework.aot.hint.ExecutableHints;
import org.springframework.aot.hint.ResourceHints;
import org.springframework.aot.hint.ReflectionHints;
import java.util.Set;
import org.springframework.ai.chat.messages.AbstractMessage;
import org.springframework.ai.chat.messages.AssistantMessage;
import org.springframework.ai.chat.messages.Message;
import org.springframework.ai.chat.messages.MessageType;
import org.springframework.ai.chat.messages.SystemMessage;
import org.springframework.ai.chat.messages.ToolResponseMessage;
import org.springframework.ai.chat.messages.UserMessage;
import org.springframework.ai.model.function.DefaultFunctionCallbackResolver;
import org.springframework.ai.model.function.FunctionCallback;
import org.springframework.aot.hint.ExecutableMode;
import org.springframework.aot.hint.RuntimeHintsRegistrar;
import org.springframework.lang.NonNull;
import org.springframework.lang.Nullable; 
 public class SpringAiCoreRuntimeHints461Test {

/*ROOST_METHOD_HASH=registerHints_a9eb20a924
ROOST_METHOD_SIG_HASH=registerHints_4cbaa06045

*/@Test
@Tag("valid")
public void registerReflectionTypeForChatMessages() {
    
    RuntimeHints hints = new RuntimeHints();
    SpringAiCoreRuntimeHints springAiCoreRuntimeHints = new SpringAiCoreRuntimeHints();
    
    springAiCoreRuntimeHints.registerHints(hints, null);
    ReflectionHints reflectionHints = hints.reflection();
    
    assertTrue(reflectionHints.isTypeRegistered(AbstractMessage.class), "AbstractMessage type should be registered");
    assertTrue(reflectionHints.isTypeRegistered(AssistantMessage.class), "AssistantMessage type should be registered");
    assertTrue(reflectionHints.isTypeRegistered(ToolResponseMessage.class), "ToolResponseMessage type should be registered");
    assertTrue(reflectionHints.isTypeRegistered(Message.class), "Message type should be registered");
    assertTrue(reflectionHints.isTypeRegistered(MessageType.class), "MessageType type should be registered");
    assertTrue(reflectionHints.isTypeRegistered(UserMessage.class), "UserMessage type should be registered");
    assertTrue(reflectionHints.isTypeRegistered(SystemMessage.class), "SystemMessage type should be registered");
    assertTrue(reflectionHints.isTypeRegistered(DefaultFunctionCallbackResolver.class), "DefaultFunctionCallbackResolver type should be registered");
    assertTrue(reflectionHints.isTypeRegistered(FunctionCallback.class), "FunctionCallback type should be registered");
}

/*ROOST_METHOD_HASH=registerHints_a9eb20a924
ROOST_METHOD_SIG_HASH=registerHints_4cbaa06045

*/@Test
@Tag("valid")
public void registerReflectionMethods() {
    
    RuntimeHints hints = new RuntimeHints();
    SpringAiCoreRuntimeHints springAiCoreRuntimeHints = new SpringAiCoreRuntimeHints();
    
    springAiCoreRuntimeHints.registerHints(hints, null);
    ExecutableHints executableHints = hints.reflection();
    
    Method getDescription = ReflectionUtils.findMethod(FunctionCallback.class, "getDescription");
    assertNotNull(getDescription, "getDescription method should exist");
    assertTrue(executableHints.isMethodRegistered(getDescription, ExecutableMode.INVOKE), "getDescription method should be registered");
    Method getInputTypeSchema = ReflectionUtils.findMethod(FunctionCallback.class, "getInputTypeSchema");
    assertNotNull(getInputTypeSchema, "getInputTypeSchema method should exist");
    assertTrue(executableHints.isMethodRegistered(getInputTypeSchema, ExecutableMode.INVOKE), "getInputTypeSchema method should be registered");
    Method getName = ReflectionUtils.findMethod(FunctionCallback.class, "getName");
    assertNotNull(getName, "getName method should exist");
    assertTrue(executableHints.isMethodRegistered(getName, ExecutableMode.INVOKE), "getName method should be registered");
}

/*ROOST_METHOD_HASH=registerHints_a9eb20a924
ROOST_METHOD_SIG_HASH=registerHints_4cbaa06045

*/@Test
@Tag("valid")
public void registerResources() {
    
    RuntimeHints hints = new RuntimeHints();
    SpringAiCoreRuntimeHints springAiCoreRuntimeHints = new SpringAiCoreRuntimeHints();
    
    springAiCoreRuntimeHints.registerHints(hints, null);
    ResourceHints resourceHints = hints.resources();
    
    assertTrue(resourceHints.isResourceRegistered(new ClassPathResource("antlr4/org/springframework/ai/vectorstore/filter/antlr4/Filters.g4")), "Filters.g4 resource should be registered");
    assertTrue(resourceHints.isResourceRegistered(new ClassPathResource("embedding/embedding-model-dimensions.properties")), "embedding-model-dimensions.properties resource should be registered");
}
} 