package org.springframework.ai.aot;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.springframework.aot.hint.RuntimeHints;
import org.springframework.aot.hint.RuntimeHintsRegistrar;
import org.springframework.core.io.ClassPathResource;
import org.junit.jupiter.api.Assertions.assertTrue; 
 public class KnuddelsRuntimeHints670Test {

/*ROOST_METHOD_HASH=registerHints_bc6a96ef8a
ROOST_METHOD_SIG_HASH=registerHints_4964e90a69

*/@Test
@Tag("valid")
public void registerResourceHintsCorrectPath() {
    
    RuntimeHints hints = new RuntimeHints();
    KnuddelsRuntimeHints knuddelsRuntimeHints = new KnuddelsRuntimeHints();
    
    knuddelsRuntimeHints.registerHints(hints, null);
    
    assertTrue(hints.resources().resourceRegistrations().stream().anyMatch(resource -> resource.equals(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken"))), "Resource should be correctly registered");
}

