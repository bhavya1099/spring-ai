/*ROOST_METHOD_HASH=registerHints_bc6a96ef8a
ROOST_METHOD_SIG_HASH=registerHints_4964e90a69

*/@Test
@Tag("boundary")
public void registerHintsDoesNotOverwriteExistingHints() {
    
    RuntimeHints hints = new RuntimeHints();
    hints.resources().registerResource(new ClassPathResource("/existing/resource/path"));
    KnuddelsRuntimeHints knuddelsRuntimeHints = new KnuddelsRuntimeHints();
    
    knuddelsRuntimeHints.registerHints(hints, null);
    
    assertTrue(hints.resources().resourceRegistrations().stream().anyMatch(resource -> resource.equals(new ClassPathResource("/existing/resource/path"))), "Existing resource should not be overwritten");
    assertTrue(hints.resources().resourceRegistrations().stream().anyMatch(resource -> resource.equals(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken"))), "New resource should be registered without overwriting existing hints");
}

