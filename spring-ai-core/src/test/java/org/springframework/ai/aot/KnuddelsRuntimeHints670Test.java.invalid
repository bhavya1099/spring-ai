    KnuddelsRuntimeHints knuddelsRuntimeHints = new KnuddelsRuntimeHints();
    
    knuddelsRuntimeHints.registerHints(hints, null);
    
    assertTrue(hints.resources().resourceRegistrations().stream().anyMatch(resource -> resource.equals(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken"))), "Resource should be registered even with a null ClassLoader");
