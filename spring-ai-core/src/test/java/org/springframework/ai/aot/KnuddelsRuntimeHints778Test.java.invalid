@Tag("invalid")
public void missingResourceFileHandling() {
    
    RuntimeHints hints = new RuntimeHints();
    KnuddelsRuntimeHints knuddelsHints = new KnuddelsRuntimeHints();
    
    Throwable exception = assertThrows(IllegalArgumentException.class, () -> {
        
        hints.resources().registerResource(new ClassPathResource("/fake/path.tiktoken"));
    });
    assertTrue(exception.getMessage().contains("Could not resolve resource"), "Exception should be thrown when resource file is missing.");
}

