package org.springframework.ai.aot;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.springframework.aot.hint.RuntimeHints;
import org.springframework.core.io.ClassPathResource;
import org.junit.jupiter.api.Assertions;
import org.junit.jupiter.api;
import org.springframework.aot.hint.RuntimeHintsRegistrar; 
 public class KnuddelsRuntimeHints778Test {

/*ROOST_METHOD_HASH=registerHints_bc6a96ef8a
ROOST_METHOD_SIG_HASH=registerHints_4964e90a69

*/@Test
@Tag("valid")
public void resourceRegistrationValidation() {
    
    RuntimeHints hints = new RuntimeHints();
    KnuddelsRuntimeHints knuddelsHints = new KnuddelsRuntimeHints();
    
    knuddelsHints.registerHints(hints, null);
    
    assertTrue(hints.resources().hasResource(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken")), "Resource should be registered correctly in RuntimeHints.");
}

/*ROOST_METHOD_HASH=registerHints_bc6a96ef8a
ROOST_METHOD_SIG_HASH=registerHints_4964e90a69

*/@Test
@Tag("valid")
public void nullClassLoaderHandling() {
    
    RuntimeHints hints = new RuntimeHints();
    KnuddelsRuntimeHints knuddelsHints = new KnuddelsRuntimeHints();
    
    knuddelsHints.registerHints(hints, null);
    
    assertTrue(hints.resources().hasResource(new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken")), "Resource should be registered even when the ClassLoader is null.");
}

/*ROOST_METHOD_HASH=registerHints_bc6a96ef8a
ROOST_METHOD_SIG_HASH=registerHints_4964e90a69

*/@Test
@Tag("boundary")
public void ensureResourcePathFormatIsValid() {
    
    RuntimeHints hints = new RuntimeHints();
    KnuddelsRuntimeHints knuddelsHints = new KnuddelsRuntimeHints();
    
    knuddelsHints.registerHints(hints, null);
    
    ClassPathResource resource = new ClassPathResource("/com/knuddels/jtokkit/cl100k_base.tiktoken");
    assertEquals("/com/knuddels/jtokkit/cl100k_base.tiktoken", resource.getPath(), "Resource path should match the expected format.");
}

/*ROOST_METHOD_HASH=registerHints_bc6a96ef8a
ROOST_METHOD_SIG_HASH=registerHints_4964e90a69

*/@Test
@Tag("boundary")
public void confirmSingleResourceRegistration() {
    
    RuntimeHints hints = new RuntimeHints();
    KnuddelsRuntimeHints knuddelsHints = new KnuddelsRuntimeHints();
    
    knuddelsHints.registerHints(hints, null);
    
    long registeredResourcesCount = hints.resources().streamResources().count();
    assertEquals(1L, registeredResourcesCount, "Only one resource should be registered to RuntimeHints.");
}

