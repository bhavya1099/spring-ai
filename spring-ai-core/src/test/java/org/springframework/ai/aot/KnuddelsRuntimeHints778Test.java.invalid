@Tag("integration")
public void methodOverrideAnnotationValidation() {
    
    KnuddelsRuntimeHints knuddelsHints = new KnuddelsRuntimeHints();
    
    assertDoesNotThrow(() -> knuddelsHints.registerHints(new RuntimeHints(), null), "Method should comply with @Override annotation and RuntimeHintsRegistrar contract.");
}

