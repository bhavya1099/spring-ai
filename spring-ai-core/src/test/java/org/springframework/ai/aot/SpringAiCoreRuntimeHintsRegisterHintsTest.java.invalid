package org.springframework.ai.aot;
import org.junit.jupiter.api.Tag;
import org.junit.jupiter.api.Test;
import org.springframework.aot.hint.RuntimeHints;
import org.springframework.aot.hint.RuntimeHintsRegistrar;
import org.springframework.ai.chat.messages.*;
import org.springframework.lang.Nullable;
import java.lang.reflect.Method;
import java.util.Set;
import static org.junit.jupiter.api.Assertions.assertTrue;
import org.springframework.ai.chat.messages.AbstractMessage;
import org.springframework.ai.chat.messages.AssistantMessage;
import org.springframework.ai.chat.messages.Message;
import org.springframework.ai.chat.messages.MessageType;
import org.springframework.ai.chat.messages.SystemMessage;
import org.springframework.ai.chat.messages.ToolResponseMessage;
import org.springframework.ai.chat.messages.UserMessage;
import org.springframework.ai.model.function.DefaultFunctionCallbackResolver;
import org.springframework.ai.model.function.FunctionCallback;
import org.springframework.aot.hint.ExecutableMode;
import org.springframework.core.io.ClassPathResource;
import org.springframework.lang.NonNull;
import org.springframework.util.ReflectionUtils;

public class SpringAiCoreRuntimeHintsRegisterHintsTest {
    private final SpringAiCoreRuntimeHints springAiCoreRuntimeHints = new SpringAiCoreRuntimeHints();
    @Test
    @Tag("valid")
    public void ensureReflectionRegistrationForChatTypes() {
        // Arrange
        RuntimeHints hints = new RuntimeHints();
        // Act
        springAiCoreRuntimeHints.registerHints(hints, null);
        // Assert
        Set<Class<?>> expectedClasses = Set.of(
                AbstractMessage.class,
                AssistantMessage.class,
                ToolResponseMessage.class,
                Message.class,
                MessageType.class,
                UserMessage.class,
                SystemMessage.class,
                DefaultFunctionCallbackResolver.class,
                FunctionCallback.class
        );
        for (Class<?> c : expectedClasses) {
            assertTrue(hints.reflection().isRegistered(c), String.format("Type %s should be registered for reflection.", c.getName()));
        }
    }
    @Test
    @Tag("valid")
    public void ensureReflectionRegistrationForMethods() {
        // Arrange
        RuntimeHints hints = new RuntimeHints();
        // Act
        springAiCoreRuntimeHints.registerHints(hints, null);
        // Assert
        Method getDescriptionMethod = ReflectionUtils.findMethod(FunctionCallback.class, "getDescription");
        assertTrue(hints.reflection().isRegistered(getDescriptionMethod, ExecutableMode.INVOKE),
                "Method getDescription should be registered for reflection.");
        Method getInputTypeSchemaMethod = ReflectionUtils.findMethod(FunctionCallback.class, "getInputTypeSchema");
        assertTrue(hints.reflection().isRegistered(getInputTypeSchemaMethod, ExecutableMode.INVOKE),
                "Method getInputTypeSchema should be registered for reflection.");
        Method getNameMethod = ReflectionUtils.findMethod(FunctionCallback.class, "getName");
        assertTrue(hints.reflection().isRegistered(getNameMethod, ExecutableMode.INVOKE),
                "Method getName should be registered for reflection.");
    }
    @Test
    @Tag("valid")
    public void ensureResourceRegistration() {
        // Arrange
        RuntimeHints hints = new RuntimeHints();
        // Act
        springAiCoreRuntimeHints.registerHints(hints, null);
        // Assert
        assertTrue(hints.resources().isRegistered(new ClassPathResource("antlr4/org/springframework/ai/vectorstore/filter/antlr4/Filters.g4")),
                "Resource Filters.g4 should be registered.");
        assertTrue(hints.resources().isRegistered(new ClassPathResource("embedding/embedding-model-dimensions.properties")),
                "Resource embedding-model-dimensions.properties should be registered.");
    }
}