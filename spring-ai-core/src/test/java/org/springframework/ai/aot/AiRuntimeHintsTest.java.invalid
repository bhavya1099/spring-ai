    @Tag("valid") public void validateValidClassToPackage() {
        
        Class<?> validClass = SampleValidClass.class; 
        String expectedPackageName = validClass.getPackageName();
        
        Set<TypeReference> result = AiRuntimeHints.findJsonAnnotatedClassesInPackage(validClass);
        
        assertFalse(result.isEmpty(), "Result set should not be empty");
        result.forEach(typeReference -> 
            assertEquals(expectedPackageName, typeReference.getName().substring(0, typeReference.getName().lastIndexOf('.')), "Package name should match"));
    }

