        when(provider.findCandidateComponents(nestedPackageName))
                .thenReturn(Set.of(mockTypeReference("org.example.nested.OuterClass$InnerClass")));
        
        Set<TypeReference> result = AiRuntimeHints.findClassesInPackage(nestedPackageName, typeFilter);
        
        assertEquals(1, result.size());
        assertTrue(result.contains(TypeReference.of("org.example.nested.OuterClass$InnerClass")));
    }

