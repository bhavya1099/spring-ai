/*ROOST_METHOD_HASH=findClassesInPackage_1bff6d9786
ROOST_METHOD_SIG_HASH=findClassesInPackage_caabc0c4e2

*/@Test
    @Tag("integration") public void testPerformanceUnderHeavyLoad() {
        
        String heavyLoadPackageName = "org.example.large";
        TypeFilter typeFilter = new AnnotationTypeFilter(JsonInclude.class);
        ClassPathScanningCandidateComponentProvider provider = mock(ClassPathScanningCandidateComponentProvider.class);
        var mockLargeSet = Collections.nCopies(10000, mockTypeReference("org.example.large.Class"));
        when(provider.findCandidateComponents(heavyLoadPackageName)).thenReturn(Set.copyOf(mockLargeSet));
        
        long startTime = System.currentTimeMillis();
        Set<TypeReference> result = AiRuntimeHints.findClassesInPackage(heavyLoadPackageName, typeFilter);
        long endTime = System.currentTimeMillis();
        
        assertEquals(10000, result.size());
        assertTrue((endTime - startTime) < 2000); 
    }

